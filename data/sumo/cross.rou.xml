<?xml version="1.0" encoding="UTF-8"?>
<!--
    Traffic demand for the single-intersection scenario.

    Straight flows:  300 veh/h per direction (main corridor)
    Turning flows:   100 veh/h per turning movement

    Total: ~1600 veh/h entering the network → creates realistic congestion
    at a level the RL agent can meaningfully reduce.

    Episode length: 200 steps × 10 sim-steps = 2000 sim-seconds
    The flow end=3600 covers the full simulation period.
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="car" accel="2.6" decel="4.5" length="5.0"
           maxSpeed="13.89" sigma="0.5" minGap="2.5"/>

    <!-- Straight-through routes -->
    <route id="NS" edges="N2C C2S"/>
    <route id="SN" edges="S2C C2N"/>
    <route id="EW" edges="E2C C2W"/>
    <route id="WE" edges="W2C C2E"/>

    <!-- Right-turn routes -->
    <route id="NW" edges="N2C C2W"/>
    <route id="SE" edges="S2C C2E"/>
    <route id="EN" edges="E2C C2N"/>
    <route id="WS" edges="W2C C2S"/>

    <!-- Left-turn routes -->
    <route id="NE" edges="N2C C2E"/>
    <route id="SW" edges="S2C C2W"/>
    <route id="ES" edges="E2C C2S"/>
    <route id="WN" edges="W2C C2N"/>

    <!-- Straight flows -->
    <flow id="f_NS" route="NS" begin="0" end="3600" vehsPerHour="300"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_SN" route="SN" begin="0" end="3600" vehsPerHour="300"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_EW" route="EW" begin="0" end="3600" vehsPerHour="300"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_WE" route="WE" begin="0" end="3600" vehsPerHour="300"
          type="car" departLane="random" departSpeed="max"/>

    <!-- Right turns -->
    <flow id="f_NW" route="NW" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_SE" route="SE" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_EN" route="EN" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_WS" route="WS" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>

    <!-- Left turns -->
    <flow id="f_NE" route="NE" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_SW" route="SW" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_ES" route="ES" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>
    <flow id="f_WN" route="WN" begin="0" end="3600" vehsPerHour="100"
          type="car" departLane="random" departSpeed="max"/>

</routes>
