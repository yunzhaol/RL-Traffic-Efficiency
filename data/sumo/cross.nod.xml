<?xml version="1.0" encoding="UTF-8"?>
<!--
    Node definitions for a single 4-way signalised intersection.
    C = centre (traffic light), N/S/E/W = peripheral boundary nodes.
-->
<nodes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/nodes_file.xsd">
    <node id="C" x="0.0"    y="0.0"    type="traffic_light"/>
    <node id="N" x="0.0"    y="300.0"  type="priority"/>
    <node id="S" x="0.0"    y="-300.0" type="priority"/>
    <node id="E" x="300.0"  y="0.0"    type="priority"/>
    <node id="W" x="-300.0" y="0.0"    type="priority"/>
</nodes>
